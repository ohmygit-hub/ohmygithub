# Required: GitHub OAuth App client id (baked into the app at build time).
OAUTH_CLIENT_ID=

# Optional: override the app/bundle id (defaults to electron-builder.yml's appId).
# APP_ID=app.oh-my-github

# --- Optional: macOS code signing / notarization (leave blank = unsigned build) ---
# CSC_LINK: path to a .p12, or a base64-encoded .p12 string
# CSC_LINK=
# CSC_KEY_PASSWORD=
# Alternative names accepted by scripts/with-env.mjs for compatibility with CI templates.
# APPLE_CERTIFICATE=
# APPLE_CERTIFICATE_PASSWORD=
# To also notarize, set the App Store Connect API key values below.
# APPLE_API_KEY: path to an AuthKey_*.p8 file, pasted PEM, or a base64-encoded .p8 string
# APPLE_API_KEY=
# APPLE_API_KEY_ID=
# APPLE_API_ISSUER=
# APPLE_TEAM_ID=

# --- Optional: Cloudflare R2 (public download + update manifest) ---
# R2_ACCOUNT_ID / R2_BUCKET + the access keys let the publish workflow upload installers.
# R2_PUBLIC_BASE_URL is the public URL the files are served from; setting it also makes the
# build emit latest*.yml (the update manifest a future in-app "check for updates" can read).
# R2_ACCOUNT_ID=
# R2_BUCKET=
# R2_PUBLIC_BASE_URL=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
