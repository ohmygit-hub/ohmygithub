{
  "name": "@oh-my-github/client",
  "version": "0.0.13",
  "private": true,
  "description": "Electron desktop client for Oh My GitHub.",
  "author": "Oh My GitHub",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "pnpm run build && node scripts/with-env.mjs electron-builder",
    "package:dir": "pnpm run build && node scripts/with-env.mjs electron-builder --dir",
    "package:mac": "pnpm run build && node scripts/with-env.mjs electron-builder --mac",
    "package:win": "pnpm run build && node scripts/with-env.mjs electron-builder --win --x64",
    "package:win:arm64": "pnpm run build && node scripts/with-env.mjs electron-builder --win --arm64",
    "package:linux": "pnpm run build && node scripts/with-env.mjs electron-builder --linux",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "generate:tray-icons": "node scripts/generate-tray-icons.mjs"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource/maple-mono": "^5.2.6",
    "@internationalized/date": "^3.12.2",
    "@oh-my-github/api": "workspace:*",
    "@oh-my-github/ui": "workspace:*",
    "@pinia/colada": "^1.3.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/vue-table": "^8.21.3",
    "@tanstack/vue-virtual": "^3.13.30",
    "@terrastruct/d2": "^0.1.33",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.3.0",
    "@vueuse/integrations": "^14.3.0",
    "animate.css": "^4.1.1",
    "echarts": "^6.1.0",
    "electron-updater": "^6.6.2",
    "fuse.js": "^7.4.2",
    "katex": "^0.17.0",
    "lucide-vue-next": "^0.562.0",
    "markstream-vue": "1.0.5-beta.0",
    "mermaid": "^11.16.0",
    "monaco-editor": "^0.55.1",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "shiki": "^4.3.0",
    "sortablejs": "^1.15.7",
    "stream-markdown": "^0.0.16",
    "stream-monaco": "^0.0.45",
    "tw-animate-css": "^1.4.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.22",
    "vue-echarts": "^8.0.1",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/sortablejs": "^1.15.9",
    "@vitejs/plugin-vue": "^6.0.7",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "6.0.0-beta.1",
    "sharp": "^0.35.3",
    "typescript": "^5.8.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.0.4"
  }
}
