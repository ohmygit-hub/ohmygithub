{
  "name": "oh-my-github",
  "version": "0.1.0",
  "private": true,
  "description": "A faster GitHub workspace for notifications, pull requests, reviews, and actions.",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "env:setup": "pnpm install && pnpm --filter @oh-my-github/client exec install-electron",
    "dev": "pnpm --filter @oh-my-github/client dev",
    "build": "pnpm -r build",
    "build:client": "pnpm --filter @oh-my-github/client build",
    "package": "pnpm package:client",
    "package:client": "pnpm --filter @oh-my-github/client build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.0.7",
    "typescript": "^5.8.3"
  }
}
